# Flask API Configuration
# Base URL for the Flask API backend
FACE_API_URL=http://localhost:5000

# Camera Configuration
# Camera device index (0 for default camera, 1, 2, etc. for additional cameras)
CAMERA_INDEX=0

# Camera frame width in pixels
CAMERA_WIDTH=640

# Camera frame height in pixels
CAMERA_HEIGHT=480

# API timeout in seconds
API_TIMEOUT=5

# Maximum frames per second to process
MAX_FPS=10

# JPEG compression quality (0-100, higher = better quality but larger payload)
JPEG_QUALITY=85
