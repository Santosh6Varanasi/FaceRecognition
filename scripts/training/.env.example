# API-Based Training Script Environment Configuration
# Copy this file to .env and update with your values

# Flask API Configuration
FLASK_API_URL=http://localhost:5001

# Database Configuration (required for migration features)
DATABASE_URL=postgresql://admin:admin@localhost:5432/face_recognition

# Optional: Training Data Directory (can also use --training-data-dir flag)
# TRAINING_DATA_DIR=training_data/training_data

# Optional: Model Directory
# MODEL_DIR=face_recognition_app/models

# Optional: Export Directory
# EXPORT_DIR=exports
