# ============================================================
# Flask API — Environment Variables Template
# Copy this file to .env and fill in your values.
# ============================================================

# PostgreSQL connection URL
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://admin:admin@localhost:5432/face_recognition

# DeepFace recognition model (ArcFace recommended for 512-d embeddings)
RECOGNITION_MODEL=ArcFace

# Face detector backend used by DeepFace
DETECTOR_BACKEND=mtcnn

# SVM confidence threshold — faces below this probability are saved as unknown
SVM_CONFIDENCE_THRESHOLD=0.50

# Port the Flask development server listens on
FLASK_PORT=5000

# Directory where cropped unknown face JPEG thumbnails are stored
UNKNOWN_FACE_IMAGES_DIR=./unknown_face_images

# Directory where training images are stored
TRAINING_IMAGES_DIR=/app/training_images

# Maximum upload file size in bytes (default: 10 MB)
MAX_CONTENT_LENGTH=10485760

# Face detector backend for training images
TRAINING_DETECTOR_BACKEND=mtcnn

# Validation cache TTL in seconds (default: 1 hour)
VALIDATION_CACHE_TTL=3600

# Allowed CORS origins — use * for development, restrict in production
# Example: http://localhost:3000,http://localhost:4200
CORS_ORIGINS=http://localhost:3000,http://localhost:4200
